#!/bin/sh

echo "🔍 Running pre-push checks..."

set -e

changed=$(git diff --name-only HEAD @{u})

ran_any=false

if echo "$changed" | grep -q "^api/"; then
  echo "📦 API changes detected — running lint & typecheck..."
  npm --prefix api run lint
  npm --prefix api run typecheck
  ran_any=true
fi

if echo "$changed" | grep -q "^web/"; then
  echo "🎨 Web changes detected — running lint, typecheck & build..."
  npm --prefix web run lint
  npm --prefix web run typecheck
  npm --prefix web run build
  ran_any=true
fi

if [ "$ran_any" = false ]; then
  echo "ℹ️  No api/web changes in this push — skipping checks."
fi

echo "✅ Pre-push checks passed!"