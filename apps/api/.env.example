# Environment mode (development, production, test)
NODE_ENV=development

# Port for the server to listen on
PORT=5000

# Google Places API (New) Key (Required)
GOOGLE_PLACES_API_KEY=your_google_api_key_here

# Cache TTL (24 hours = 86400 seconds)
CACHE_TTL_SECONDS=86400

# Rate Limiting: Maximum 5 requests per 1 minute
THROTTLER_TTL_MS=60000
THROTTLER_LIMIT=5

# Documentation (Swagger)
SWAGGER_TITLE=ProfileLens API
SWAGGER_DESCRIPTION=API for Google Business Profile optimization analysis
SWAGGER_VERSION=1.0

# CORS Origins
FRONTEND_DEV_URL=http://localhost:3000
FRONTEND_PROD_URL=https://profilelens.com