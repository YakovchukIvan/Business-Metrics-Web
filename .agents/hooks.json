{
  "profilelens-guardrails": {
    "enabled": true,
    "PreToolUse": [
      {
        "matcher": "run_command",
        "hooks": [
          {
            "type": "command",
            "command": "node hooks/pre_command.js",
            "timeout": 30
          }
        ]
      },
      {
        "matcher": "write_to_file|multi_replace_file_content|replace_file_content",
        "hooks": [
          {
            "type": "command",
            "command": "node hooks/pre_edit.js",
            "timeout": 30
          }
        ]
      },
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "node hooks/hello.js",
            "timeout": 30
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "write_to_file|multi_replace_file_content|replace_file_content",
        "hooks": [
          {
            "type": "command",
            "command": "node hooks/post_edit.js",
            "timeout": 60,
            "async": true
          }
        ]
      }
    ],
    "Stop": [
      {
        "type": "command",
        "command": "node hooks/on_stop.js",
        "timeout": 30
      }
    ]
  }
}
